exports.createGameQuestion = async (req, res) => {
  try {
    // 🔥 only caregiver allowed
    if (req.user.role !== "caregiver") {
      return res.status(403).json({ message: "Only caregiver can create questions" });
    }

    const { question, options, correctAnswer, image } = req.body;

    if (!question || !options || !correctAnswer) {
      return res.status(400).json({ message: "Missing required fields" });
    }

    const game = new AlzMemoryGame({
      patientId: req.user.linkedPatientId,
      question,
      options,
      correctAnswer,
      image,
      createdBy: req.user._id,
    });

    await game.save();

    res.status(201).json({
      success: true,
      game,
    });

  } catch (error) {
    console.error("Create game question error:", error);
    res.status(500).json({ message: "Failed to create question" });
  }
};

