//Alerts
exports.geofenceAlert = async (req, res) => {
  try {
    const { lat, lng, address, type } = req.body;
    
    // Resolve patientId safely regardless of patient vs caregiver caller
    let patientId = req.user.linkedPatientId;
    if (req.user.role === 'patient') {
        const BaseAlzheimer = require('../models/Alzheimer');
        const BaseElderly = require('../models/Elderly');
        const alz = await BaseAlzheimer.findOne({ userId: req.user._id });
        if (alz) patientId = alz._id;
        else {
            const eld = await BaseElderly.findOne({ userId: req.user._id });
            if (eld) patientId = eld._id;
        }
    }

    if (!patientId) patientId = req.user._id;

    // basic validation
    if (!lat || !lng) {
      return res.status(400).json({ message: "Location required" });
    }
    
    // We parse the alert classification or fallback to geofence
    const alertType = type || "geofence";

    const lastAlert = await Alert.findOne({ patientId, type: alertType })
      .sort({ createdAt: -1 });

    if (lastAlert && lastAlert.acknowledged === false) {
      // Update existing alert with new coordinates (WITHOUT calling Nominatim again to save costs)
      lastAlert.lat = lat;
      lastAlert.lng = lng;
      // We keep the first address for context, or just update the raw coords
      if (address) {
        lastAlert.address = address;
      }
      await lastAlert.save();

      return res.json({
        success: true,
        message: "Existing alert updated with latest location",
      });
    }

    const alert = new Alert({
      patientId,
      type: alertType,
      lat,
      lng,
      address,
    });

    await alert.save();

    console.log("🚨 GEOFENCE ALERT:", address);

    res.json({
      success: true,
      message: "Alert recorded",
    });

  } catch (error) {
    console.error("Alert error:", error);
    res.status(500).json({ message: "Failed to record alert" });
  }
};

exports.getAlerts = async (req, res) => {
  try {
    const BaseAlzheimer = require('../models/Alzheimer');
    const BaseElderly = require('../models/Elderly');

    let possibleIds = [req.user.linkedPatientId, req.user._id];
    
    // Attempt to aggregate cross-profile alerts to avoid the "Elderly Caregiver can't see Alzheimer generated alerts" bug
    if (req.user.role === 'caregiver' || req.user.role === 'guardian') {
       let baseUserId = null;
       
       let alzProfile = await BaseAlzheimer.findById(req.user.linkedPatientId);
       if (alzProfile) baseUserId = alzProfile.userId;
       
       if (!baseUserId) {
           let eldProfile = await BaseElderly.findById(req.user.linkedPatientId);
           if (eldProfile) baseUserId = eldProfile.userId;
       }

       if (baseUserId) {
           const allAlz = await BaseAlzheimer.findOne({ userId: baseUserId });
           const allEld = await BaseElderly.findOne({ userId: baseUserId });
           if (allAlz) possibleIds.push(allAlz._id);
           if (allEld) possibleIds.push(allEld._id);
       }
    }

    const alerts = await Alert.find({ patientId: { $in: possibleIds } })
      .sort({ createdAt: -1 });

    res.json({
      success: true,
      alerts,
    });

  } catch (error) {
    console.error("Fetch alerts error:", error);
    res.status(500).json({ message: "Failed to fetch alerts" });
  }
};

