// CREATE TASK
exports.createTask = async (req, res) => {
  try {
    const { text, dueTime, isPrivate } = req.body;

    if (!text) {
      return res.status(400).json({ message: "Task text is required" });
    }

    // 🔥 CORE LOGIC
    const patientId = req.user.linkedPatientId;

    const task = new AlzTask({
      patientId,
      text,
      createdBy: req.user._id,
      createdByRole: req.user.role,
      dueTime: dueTime || null,
      isPrivate: isPrivate || false,
    });

    await task.save();

    res.status(201).json({
      success: true,
      task,
    });

  } catch (error) {
    console.error("Create task error:", error);
    res.status(500).json({ message: "Failed to create task" });
  }
};

exports.getTasks = async (req, res) => {
  try {
    const patientId = req.user.linkedPatientId;
    const isPatient = req.user.role === "patient";

    // If patient, hide private tasks. If caregiver, show everything for this patient.
    const query = { patientId };
    if (isPatient) {
      query.isPrivate = { $ne: true };
    }

    const tasks = await AlzTask.find(query)
      .populate("createdBy", "name email")
      .sort({ createdAt: -1 });

    res.json({
      success: true,
      tasks,
    });

  } catch (error) {
    console.error("Fetch tasks error:", error);
    res.status(500).json({ message: "Failed to fetch tasks" });
  }
};

exports.updateTaskStatus = async (req, res) => {
  try {
    const { id } = req.params;
    const { status } = req.body;

    if (!["pending", "done"].includes(status)) {
      return res.status(400).json({ message: "Invalid status" });
    }

    const task = await AlzTask.findById(id);

    if (!task) {
      return res.status(404).json({ message: "Task not found" });
    }

    // 🔥 PERMISSION CHECK
    // Allow if:
    // 1. User is the creator
    // 2. User is the linked patient
    // 3. User is a caregiver
    if (
      task.createdBy.toString() !== req.user._id.toString() &&
      task.patientId.toString() !== req.user.linkedPatientId?.toString() &&
      req.user.role !== "caregiver"
    ) {
      console.log(`[AUTH FAIL] User ${req.user._id} (${req.user.role}) tried to update task ${id}. PatientId: ${task.patientId}, LinkedPatientId: ${req.user.linkedPatientId}`);
      return res.status(403).json({ message: "Not authorized" });
    }

    task.status = status;

    await task.save();

    res.json({
      success: true,
      task,
    });

  } catch (error) {
    console.error("Update status error:", error);
    res.status(500).json({ message: "Failed to update status" });
  }
};

