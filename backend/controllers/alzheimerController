const { AlzTask, AlzNote, AlzMemoryGame, GameResult, AlzContact, Geofence, Alert } = require("../models/Alzheimer.model");

// CREATE NOTE
exports.createNote = async (req, res) => {
  try {
    const { text, status } = req.body;

    if (!text) {
      return res.status(400).json({ message: "Note text is required" });
    }

    const patientId = req.user.linkedPatientId;

    const note = new AlzNote({
      patientId,
      text,
      status: status || "pending",
      createdBy: req.user._id,
      createdByRole: req.user.role,
    });

    await note.save();

    res.status(201).json({
      success: true,
      note,
    });

  } catch (error) {
    console.error("Create note error:", error);
    res.status(500).json({ message: "Failed to create note" });
  }
};

// UPDATE NOTE STATUS (Dedicated)
exports.updateNoteStatus = async (req, res) => {
  try {
    const { id } = req.params;
    const { status } = req.body;

    const validStatuses = ["pending", "acknowledged", "completed"];
    if (!validStatuses.includes(status)) {
      return res.status(400).json({ message: "Invalid status value" });
    }

    const note = await AlzNote.findById(id);
    if (!note) return res.status(404).json({ message: "Note not found" });

    // Permission check: caregiver or linked patient
    const isCaregiver = req.user.role === "caregiver";
    const isPatient = note.patientId.toString() === req.user.linkedPatientId?.toString();

    if (!isCaregiver && !isPatient) {
      return res.status(403).json({ message: "Not authorized to update this status" });
    }

    note.status = status;
    await note.save();

    res.json({ success: true, note });
  } catch (error) {
    console.error("Update note status error:", error);
    res.status(500).json({ message: "Failed to update note status" });
  }
};


