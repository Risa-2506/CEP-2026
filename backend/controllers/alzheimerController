//GEOFENCE
exports.setGeofence = async (req, res) => {
  try {
    const { centerLat, centerLng, radius } = req.body;

    const patientId = req.user.linkedPatientId;

    let geofence = await Geofence.findOne({ patientId });

    if (geofence) {
      // update existing
      geofence.centerLat = centerLat;
      geofence.centerLng = centerLng;
      geofence.radius = radius;
    } else {
      // create new
      geofence = new Geofence({
        patientId,
        centerLat,
        centerLng,
        radius,
      });
    }

    await geofence.save();

    res.json({
      success: true,
      geofence,
    });

  } catch (error) {
    console.error("Geofence error:", error);
    res.status(500).json({ message: "Failed to set geofence" });
  }
};

